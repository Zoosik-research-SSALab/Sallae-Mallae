# Deprecated for server deployment.
# Use infra/env/*.env.example for branch-specific app envs and infra/env/base.env.example for shared DB/Redis.

# nginx
NGINX_PORT=80

# optional profiles
# COMPOSE_PROFILES=fullstack

# app runtime target (dev or prod)
SPRING_PROFILE=dev
JAVA_TOOL_OPTIONS=-Xms256m -Xmx1024m

# spring app DB target
APP_DB_NAME=app_dev
APP_DB_USER=app_dev_user
APP_DB_PASSWORD=change_me_dev

# worker DB target
WORKER_DB_NAME=app_dev
WORKER_DB_USER=app_dev_user
WORKER_DB_PASSWORD=change_me_dev

# postgres superuser
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASSWORD=postgres

# logical DB separation in a single postgres instance
DEV_DB_NAME=app_dev
DEV_DB_USER=app_dev_user
DEV_DB_PASSWORD=change_me_dev

PROD_DB_NAME=app_prod
PROD_DB_USER=app_prod_user
PROD_DB_PASSWORD=change_me_prod
