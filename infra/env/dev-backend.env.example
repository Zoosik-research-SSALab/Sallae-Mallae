DEPLOY_ENV=dev-backend
COMPOSE_PROJECT_NAME=sallae-dev-backend
APP_NETWORK_NAME=sallae-dev-backend-net
NGINX_PORT=8082
SPRING_PROFILE=dev
JAVA_TOOL_OPTIONS=-Xms256m -Xmx1024m

APP_DB_NAME=app
APP_DB_USER=app_user
APP_DB_PASSWORD=change_me_app

AI_SERVER_BASE_URL=http://ml-server:8000
KIS_MODE=paper
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=
KIS_REFRESH_MARGIN_SECONDS=120
KIS_TIMEOUT_SECONDS=8
KIS_RETRY_ATTEMPTS=1
KIS_RETRY_BACKOFF_MILLIS=250
KIS_REALTIME_SUBSCRIPTION_TTL_MINUTES=30
KIS_REALTIME_SUBSCRIPTION_ACK_TIMEOUT_SECONDS=7
JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters-long
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=
OAUTH_NAVER_REDIRECT_URI=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=
OAUTH_KAKAO_REDIRECT_URI=
MINIO_ENDPOINT=
MINIO_PRESIGNED_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_PUBLIC_URL=
