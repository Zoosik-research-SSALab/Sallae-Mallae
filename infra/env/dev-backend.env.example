DEPLOY_ENV=dev-backend
COMPOSE_PROJECT_NAME=sallae-dev-backend
APP_NETWORK_NAME=sallae-dev-backend-net
NGINX_PORT=8082
SPRING_PROFILE=dev
JAVA_TOOL_OPTIONS=-Xms256m -Xmx1024m

# ==============================================
# 로컬 개발 환경 설정
# 이 파일을 .env로 복사해서 사용하세요
# cp .env.example .env
# ==============================================

# ---- Spring Boot 환경변수 ----
# DB
DB_HOST=localhost
DB_PORT=5432
APP_DB_NAME=app
APP_DB_USER=app_user
APP_DB_PASSWORD=change_me_app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (32자 이상)
JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters-long

# Mail (SMTP) - Gmail 앱 비밀번호: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# OAuth (Google)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=

# OAuth (Naver)
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=
OAUTH_NAVER_REDIRECT_URI=

# OAuth (Kakao)
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=
OAUTH_KAKAO_REDIRECT_URI=
