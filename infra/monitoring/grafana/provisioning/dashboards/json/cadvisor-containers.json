{
  "title": "cAdvisor Containers",
  "uid": "cadvisor-containers",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Container CPU Usage (cores)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\",image!=\"\"}[5m]))",
          "legendFormat": "{{name}}",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Container Memory Working Set",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (name) (container_memory_working_set_bytes{name!=\"\",image!=\"\"})",
          "legendFormat": "{{name}}",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Container Network Receive",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\",image!=\"\"}[5m]))",
          "legendFormat": "{{name}}",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Container Network Transmit",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!=\"\",image!=\"\"}[5m]))",
          "legendFormat": "{{name}}",
          "range": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Running Containers Seen",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "count(count by (name) (container_last_seen{name!=\"\",image!=\"\"}))",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 6,
      "title": "Top CPU Containers",
      "type": "table",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "topk(10, sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\",image!=\"\"}[5m])))",
          "instant": true,
          "range": false,
          "format": "table"
        }
      ]
    }
  ]
}
