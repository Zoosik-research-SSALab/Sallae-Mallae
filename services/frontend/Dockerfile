FROM node:22-alpine

WORKDIR /app

ARG NEXT_PUBLIC_API_MOCKING
ARG NEXT_PUBLIC_OAUTH_GOOGLE_CLIENT_ID
ARG NEXT_PUBLIC_OAUTH_KAKAO_CLIENT_ID
ARG NEXT_PUBLIC_OAUTH_NAVER_CLIENT_ID
ARG NEXT_PUBLIC_OAUTH_GOOGLE_REDIRECT_URI
ARG NEXT_PUBLIC_OAUTH_KAKAO_REDIRECT_URI
ARG NEXT_PUBLIC_OAUTH_NAVER_REDIRECT_URI

ENV NEXT_PUBLIC_API_MOCKING=${NEXT_PUBLIC_API_MOCKING}
ENV NEXT_PUBLIC_OAUTH_GOOGLE_CLIENT_ID=${NEXT_PUBLIC_OAUTH_GOOGLE_CLIENT_ID}
ENV NEXT_PUBLIC_OAUTH_KAKAO_CLIENT_ID=${NEXT_PUBLIC_OAUTH_KAKAO_CLIENT_ID}
ENV NEXT_PUBLIC_OAUTH_NAVER_CLIENT_ID=${NEXT_PUBLIC_OAUTH_NAVER_CLIENT_ID}
ENV NEXT_PUBLIC_OAUTH_GOOGLE_REDIRECT_URI=${NEXT_PUBLIC_OAUTH_GOOGLE_REDIRECT_URI}
ENV NEXT_PUBLIC_OAUTH_KAKAO_REDIRECT_URI=${NEXT_PUBLIC_OAUTH_KAKAO_REDIRECT_URI}
ENV NEXT_PUBLIC_OAUTH_NAVER_REDIRECT_URI=${NEXT_PUBLIC_OAUTH_NAVER_REDIRECT_URI}

COPY package.json ./
RUN corepack enable \
    && corepack prepare pnpm@latest --activate \
    && pnpm install --no-frozen-lockfile

COPY . .

RUN pnpm run build

EXPOSE 3000

CMD ["pnpm", "run", "start"]
