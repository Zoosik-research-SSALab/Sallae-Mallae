# client-side API routing
# enabled: frontend local mock routes (/api/*)
# disabled: real backend base URL
NEXT_PUBLIC_API_MOCKING=disabled

# ex) http://localhost:8080 or https://j14d208.p.ssafy.io
NEXT_PUBLIC_API_BASE_URL=https://j14d208.p.ssafy.io

# used when NEXT_PUBLIC_API_MOCKING=enabled
# current frontend mock routes live under /api/*
NEXT_PUBLIC_MOCK_BASE_URL=/api

# server-side auth proxy target
# auth routes proxy to {AUTH_API_BASE_URL}/api/auth/*
AUTH_API_BASE_URL=https://j14d208.p.ssafy.io
