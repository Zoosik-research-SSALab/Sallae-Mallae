# client-side API routing
# enabled: frontend local mock routes (/api/*)
# disabled: real backend base URL
NEXT_PUBLIC_API_MOCKING=disabled

# ex) http://localhost:8080 or http://j14d208.p.ssafy.io
NEXT_PUBLIC_API_BASE_URL=http://j14d208.p.ssafy.io

# used when NEXT_PUBLIC_API_MOCKING=enabled
# current frontend mock routes live under /api/*
NEXT_PUBLIC_MOCK_BASE_URL=/api

# server-side login proxy settings
# true: use local mock user for /api/auth/login
AUTH_USE_MOCK=false

# used when AUTH_USE_MOCK=false
# the login route proxies to {AUTH_API_BASE_URL}/api/auth/login
AUTH_API_BASE_URL=http://j14d208.p.ssafy.io
