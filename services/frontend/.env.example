# client-side API routing
# true: frontend local mock routes (/api/*)
# false: real backend base URL
# legacy values `enabled` / `disabled` are still supported for compatibility
NEXT_PUBLIC_API_MOCKING=false

# ex) http://localhost:8080 or https://j14d208.p.ssafy.io
NEXT_PUBLIC_API_BASE_URL=https://j14d208.p.ssafy.io

# used when NEXT_PUBLIC_API_MOCKING=true
# current frontend mock routes live under /api/*
NEXT_PUBLIC_MOCK_BASE_URL=/api

# server-side auth proxy target
# auth routes proxy to {AUTH_API_BASE_URL}/api/auth/*
AUTH_API_MOCKING=false
AUTH_API_BASE_URL=https://j14d208.p.ssafy.io

# server-side OAuth authorize URL config for frontend route handlers
# redirect URI should point to the public frontend callback route
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_REDIRECT_URI=
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_REDIRECT_URI=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_REDIRECT_URI=
