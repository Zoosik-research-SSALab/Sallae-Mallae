# 데이터 저장 경로 (기본값: ./data, Docker: /data)
BASE_PATH=./data

# API 키
DART_API_KEY=your_dart_api_key_here
FRED_API_KEY=your_fred_api_key_here
KRX_USER_ID=your_krx_user_id_here
KRX_PASSWORD=your_krx_password_here
KIS_API_KEY=your_kis_api_key_here
KIS_SECRET_KEY=your_kis_secret_key_here

# rclone 동기화 설정 (선택)
RCLONE_REMOTE=gdrive:kospi200-project
RCLONE_AUTO_SYNC=false

# DB 연결 (loaders, collectors에서 사용)
DB_HOST=localhost
DB_PORT=15432
DB_NAME=app
DB_USER=app_user
DB_PASSWORD=your_db_password_here