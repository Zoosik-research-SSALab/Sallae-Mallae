DEBUG=false

AI_SERVER_BASE_URL=http://localhost:8000
INTERNAL_API_KEY=change_me_ai_internal_key

LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_REQUEST_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.2

DEBATE_VERSION=debate-v1
MAX_DEBATE_ROUNDS=3
NEWS_LIMIT=8
FINANCIAL_LIMIT=4
MAX_TARGETS_PER_RUN=200

TARGET_SOURCE=trading_history
TARGET_MARKET_TYPE=KOSPI
TARGET_PORTFOLIO_ID=

LOOP_INTERVAL_SECONDS=300
MAX_RETRY_ATTEMPTS=5
RETRY_BACKOFF_SECONDS=30
JOB_LEASE_SECONDS=900

WORKER_NAME=desktop-worker-01
STATE_DIR=./state

